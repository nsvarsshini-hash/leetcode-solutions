class Solution:
    def maxVowels(self, s: str, k: int) -> int:
        vowel=['a','e','i','o','u']
        count=0
        max1=0
        for i in range(k):
            if s[i] in vowel:
                count+=1
            max1=count
        for i in range(k,len(s)):
            if s[i] in vowel:
                count+=1
            if s[i-k] in vowel:
                count-=1
            max1=max(max1,count)
        return max1
