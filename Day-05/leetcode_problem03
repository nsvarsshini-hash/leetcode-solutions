class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        freq=[-1]*256
        l=0
        r=0
        max1=0
        while(r<len(s)):
            if l<=freq[ord(s[r])]:
                l=freq[ord(s[r])]+1
            length=r-l+1
            max1=max(length,max1)
            freq[ord(s[r])]=r
            r+=1
        return max1

